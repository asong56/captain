{
  "manifest_version": 3,
  "name": "Captain",
  "version": "1.0.0",
  "description": "One helm, open seas. Proxy, privacy, focus, vault, AI, and tab control \u2014 unified.",
  "permissions": [
    "tabs",
    "activeTab",
    "bookmarks",
    "browsingData",
    "history",
    "scripting",
    "search",
    "storage",
    "unlimitedStorage",
    "sessions",
    "alarms",
    "webNavigation",
    "contextMenus",
    "offscreen",
    "privacy",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "proxy",
    "management",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "commands": {
    "open-captain": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Captain command palette"
    }
  },
  "content_scripts": [
    {
      "js": [
        "content/overlay.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "content/guard.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
        "content/annotate.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*",
        "content/overlay.css",
        "content/overlay-inner.html",
        "content/overlay-inner.js",
        "inject/*",
        "pages/*",
        "ticker.html",
        "ticker.js",
        "assets/fonts/*"
      ]
    }
  ]
}